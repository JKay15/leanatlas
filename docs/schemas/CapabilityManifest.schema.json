{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "commands": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "deps": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "description": {
            "type": "string"
          },
          "entrypoint": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "inputs": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "outputs": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "schemas": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "smoke": {
            "items": {
              "type": "string"
            },
            "type": "array"
          }
        },
        "required": [
          "id",
          "entrypoint",
          "description",
          "inputs",
          "outputs"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "phase": {
      "pattern": "^phase(3|4|5)$",
      "type": "string"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "phase",
    "commands"
  ],
  "title": "CapabilityManifest",
  "type": "object"
}
