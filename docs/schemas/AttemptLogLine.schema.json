{
  "$defs": {
    "advisor_decision": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        "hypotheses": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "category": {
                "$ref": "#/$defs/category"
              },
              "evidence": {
                "$ref": "#/$defs/evidence_refs"
              },
              "note": {
                "type": "string"
              }
            },
            "required": [
              "category"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "notes": {
          "type": "string"
        },
        "proposed_actions": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "description": {
                "type": "string"
              },
              "evidence": {
                "$ref": "#/$defs/evidence_refs"
              },
              "kind": {
                "pattern": "^[A-Z][A-Z0-9_]*$",
                "type": "string"
              },
              "patch": {
                "type": "string"
              }
            },
            "required": [
              "kind",
              "description"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "recommendation": {
          "enum": [
            "CONTINUE",
            "TRIAGE"
          ],
          "type": "string"
        }
      },
      "required": [
        "recommendation",
        "confidence",
        "hypotheses",
        "proposed_actions"
      ],
      "type": "object"
    },
    "budget": {
      "additionalProperties": false,
      "properties": {
        "counters": {
          "$ref": "#/$defs/budget_counters"
        },
        "limits": {
          "$ref": "#/$defs/budget_limits"
        }
      },
      "required": [
        "limits",
        "counters"
      ],
      "type": "object"
    },
    "budget_counters": {
      "additionalProperties": false,
      "properties": {
        "attempts_used": {
          "minimum": 0,
          "type": "integer"
        },
        "external_queries_used": {
          "minimum": 0,
          "type": "integer"
        },
        "steps_used": {
          "minimum": 0,
          "type": "integer"
        },
        "wall_time_ms": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "attempts_used",
        "steps_used",
        "external_queries_used",
        "wall_time_ms"
      ],
      "type": "object"
    },
    "budget_limits": {
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "minimum": 0,
          "type": "integer"
        },
        "max_external_queries": {
          "minimum": 0,
          "type": "integer"
        },
        "max_steps": {
          "minimum": 0,
          "type": "integer"
        },
        "max_wall_time_ms": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "max_attempts",
        "max_steps",
        "max_external_queries",
        "max_wall_time_ms"
      ],
      "type": "object"
    },
    "category": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "family": {
          "enum": [
            "IMPORT",
            "NAME",
            "TYPE",
            "TACTIC",
            "ASSUMPTION",
            "DEFINITION",
            "STATEMENT",
            "BUDGET",
            "TOOLING",
            "UNKNOWN"
          ],
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "standard": {
          "type": "boolean"
        }
      },
      "required": [
        "family",
        "code"
      ],
      "type": "object"
    },
    "event": {
      "additionalProperties": false,
      "properties": {
        "attrs": {
          "additionalProperties": true,
          "type": "object"
        },
        "kind": {
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "ts_ms": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "kind"
      ],
      "type": "object"
    },
    "evidence_refs": {
      "additionalProperties": false,
      "properties": {
        "attempt_indices": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        },
        "diagnostic_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "target_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "trace_step_indices": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        }
      },
      "type": "object"
    },
    "judge": {
      "additionalProperties": false,
      "properties": {
        "K": {
          "minimum": 0,
          "type": "integer"
        },
        "budget_exceeded": {
          "items": {
            "pattern": "^[A-Z][A-Z0-9_]*$",
            "type": "string"
          },
          "type": "array"
        },
        "decision": {
          "enum": [
            "CONTINUE",
            "TRIAGED",
            "SUCCESS"
          ],
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "reason_code": {
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "stagnant_count": {
          "minimum": 0,
          "type": "integer"
        },
        "triage_level": {
          "enum": [
            "ESCALATE",
            "FIXABLE",
            null
          ],
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "decision",
        "reason_code",
        "stagnant_count",
        "K",
        "budget_exceeded"
      ],
      "type": "object"
    },
    "patch_scope": {
      "additionalProperties": false,
      "properties": {
        "ignored_paths": {
          "items": {
            "$ref": "#/$defs/repo_path"
          },
          "type": "array"
        },
        "primary_reason_code": {
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "verdict": {
          "enum": [
            "ALLOW",
            "DISALLOW"
          ],
          "type": "string"
        },
        "violations": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "pattern": "^[A-Z][A-Z0-9_]*$",
                "type": "string"
              },
              "path": {
                "$ref": "#/$defs/repo_path"
              }
            },
            "required": [
              "path",
              "code"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "verdict",
        "primary_reason_code",
        "violations",
        "ignored_paths"
      ],
      "type": "object"
    },
    "repo_path": {
      "pattern": "^(?!/)(?!\\./)(?!.*\\\\)(?!.*\\.\\.)([A-Za-z0-9._-]+/)*[A-Za-z0-9._-]+\\.[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "stage_status": {
      "additionalProperties": false,
      "properties": {
        "diagnostic_ids": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "notes": {
          "type": "string"
        },
        "status": {
          "enum": [
            "OK",
            "FAIL",
            "SKIPPED"
          ],
          "type": "string"
        },
        "trace_step_indices": {
          "items": {
            "minimum": 0,
            "type": "integer"
          },
          "type": "array"
        }
      },
      "required": [
        "status"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "stages": {
            "properties": {
              "build": {
                "properties": {
                  "status": {
                    "const": "FAIL"
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "stages": {
            "properties": {
              "verify": {
                "properties": {
                  "status": {
                    "const": "SKIPPED"
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "advisor_decision": {
      "$ref": "#/$defs/advisor_decision"
    },
    "attempt_index": {
      "minimum": 0,
      "type": "integer"
    },
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "events": {
      "items": {
        "$ref": "#/$defs/event"
      },
      "type": "array"
    },
    "exec_spans": {
      "description": "Runner-captured command execution evidence (Phase6+).",
      "items": {
        "additionalProperties": false,
        "properties": {
          "cmd": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "minItems": 1,
            "type": "array"
          },
          "cwd": {
            "minLength": 1,
            "type": "string"
          },
          "duration_ms": {
            "minimum": 0,
            "type": "integer"
          },
          "exit_code": {
            "type": "integer"
          },
          "id": {
            "pattern": "^[A-Za-z0-9._-]+$",
            "type": "string"
          },
          "stderr_path": {
            "$ref": "#/$defs/repo_path"
          },
          "stderr_sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "stdout_path": {
            "$ref": "#/$defs/repo_path"
          },
          "stdout_sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "timed_out": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "cmd",
          "cwd",
          "exit_code",
          "stdout_path",
          "stderr_path",
          "stdout_sha256",
          "stderr_sha256",
          "duration_ms"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "judge": {
      "$ref": "#/$defs/judge"
    },
    "notes": {
      "type": "string"
    },
    "patch_scope": {
      "$ref": "#/$defs/patch_scope"
    },
    "problem_slug": {
      "pattern": "^[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "run_id": {
      "pattern": "^[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "schema": {
      "const": "leanatlas.attempt_log_line"
    },
    "schema_version": {
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "type": "string"
    },
    "signals": {
      "additionalProperties": false,
      "properties": {
        "diag_changed": {
          "type": "boolean"
        },
        "diag_fingerprint": {
          "minLength": 8,
          "type": "string"
        },
        "error_outside_problem": {
          "type": "boolean"
        },
        "goal_changed": {
          "type": "boolean"
        },
        "goal_snapshot_hash": {
          "type": "string"
        },
        "imports_changed": {
          "type": "boolean"
        },
        "new_retrieval_hit": {
          "type": "boolean"
        },
        "stagnant": {
          "type": "boolean"
        },
        "tooling_failed": {
          "type": "boolean"
        }
      },
      "required": [
        "diag_fingerprint",
        "diag_changed",
        "new_retrieval_hit",
        "imports_changed",
        "stagnant",
        "error_outside_problem"
      ],
      "type": "object"
    },
    "stages": {
      "additionalProperties": false,
      "properties": {
        "build": {
          "$ref": "#/$defs/stage_status"
        },
        "retrieval": {
          "$ref": "#/$defs/stage_status"
        },
        "verify": {
          "$ref": "#/$defs/stage_status"
        }
      },
      "required": [
        "retrieval",
        "build",
        "verify"
      ],
      "type": "object"
    },
    "suspected_category": {
      "$ref": "#/$defs/category"
    },
    "touched_files": {
      "items": {
        "$ref": "#/$defs/repo_path"
      },
      "type": "array"
    }
  },
  "required": [
    "schema",
    "schema_version",
    "run_id",
    "problem_slug",
    "attempt_index",
    "touched_files",
    "patch_scope",
    "suspected_category",
    "signals",
    "stages",
    "exec_spans",
    "judge",
    "budget"
  ],
  "title": "LeanAtlas AttemptLogLine",
  "type": "object"
}
