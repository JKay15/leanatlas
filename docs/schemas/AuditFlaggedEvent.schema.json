{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "remediation_status": {
            "const": "ACCEPTED_RISK"
          }
        }
      },
      "then": {
        "required": [
          "accepted_risk"
        ]
      }
    }
  ],
  "properties": {
    "accepted_risk": {
      "additionalProperties": false,
      "properties": {
        "approver": {
          "minLength": 1,
          "type": "string"
        },
        "rationale": {
          "minLength": 1,
          "type": "string"
        },
        "review_at_utc": {
          "format": "date-time",
          "type": "string"
        }
      },
      "required": [
        "rationale",
        "approver",
        "review_at_utc"
      ],
      "type": "object"
    },
    "category": {
      "enum": [
        "SOUNDNESS_RISK",
        "FIDELITY_DRIFT",
        "CONTRACT_NONCOMPLIANCE",
        "SECURITY_PRIVACY",
        "OPERATIONAL_RELIABILITY"
      ],
      "type": "string"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "type": "number"
    },
    "detected_at_utc": {
      "format": "date-time",
      "type": "string"
    },
    "evidence_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "flag_id": {
      "pattern": "^[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "promotion_blocked": {
      "type": "boolean"
    },
    "remediation_status": {
      "enum": [
        "OPEN",
        "IN_PROGRESS",
        "MITIGATED",
        "VERIFIED",
        "CLOSED",
        "ACCEPTED_RISK"
      ],
      "type": "string"
    },
    "run_key": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "scope": {
      "enum": [
        "NODE",
        "RUN",
        "GRAPH",
        "RESOURCE"
      ],
      "type": "string"
    },
    "severity": {
      "enum": [
        "S1_CRITICAL",
        "S2_MAJOR",
        "S3_MINOR"
      ],
      "type": "string"
    },
    "summary": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "const": "1",
      "type": "string"
    }
  },
  "required": [
    "version",
    "flag_id",
    "run_key",
    "scope",
    "category",
    "severity",
    "confidence",
    "summary",
    "evidence_refs",
    "detected_at_utc",
    "remediation_status",
    "promotion_blocked"
  ],
  "title": "AuditFlaggedEvent",
  "type": "object"
}
