{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "resolution_status": {
            "const": "CONFLICT_REJECTED"
          }
        }
      },
      "then": {
        "properties": {
          "conflicts": {
            "minItems": 1
          }
        },
        "required": [
          "conflicts"
        ]
      }
    }
  ],
  "properties": {
    "applied_chain": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {
            "minLength": 1,
            "type": "string"
          },
          "precedence": {
            "minimum": 0,
            "type": "integer"
          },
          "scope": {
            "enum": [
              "ROOT",
              "NESTED",
              "OVERRIDE"
            ],
            "type": "string"
          },
          "sha256": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          }
        },
        "required": [
          "path",
          "sha256",
          "scope",
          "precedence"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "conflicts": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "by_path": {
            "minLength": 1,
            "type": "string"
          },
          "overridden_path": {
            "minLength": 1,
            "type": "string"
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          },
          "rule_id": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "rule_id",
          "overridden_path",
          "by_path",
          "reason"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "final_mode": {
      "enum": [
        "OPERATOR",
        "MAINTAINER"
      ],
      "type": "string"
    },
    "generated_at_utc": {
      "format": "date-time",
      "type": "string"
    },
    "resolution_status": {
      "enum": [
        "RESOLVED",
        "CONFLICT_REJECTED"
      ],
      "type": "string"
    },
    "target_path": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "const": "1",
      "type": "string"
    }
  },
  "required": [
    "version",
    "target_path",
    "applied_chain",
    "resolution_status",
    "final_mode"
  ],
  "title": "InstructionResolutionReport",
  "type": "object"
}
