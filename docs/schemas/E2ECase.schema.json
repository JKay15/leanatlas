{
  "$defs": {
    "category": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "family": {
          "enum": [
            "IMPORT",
            "NAME",
            "TYPE",
            "TACTIC",
            "ASSUMPTION",
            "DEFINITION",
            "STATEMENT",
            "BUDGET",
            "TOOLING",
            "UNKNOWN"
          ],
          "type": "string"
        }
      },
      "required": [
        "family",
        "code"
      ],
      "type": "object"
    },
    "expected": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "final_status": {
                "const": "TRIAGED"
              }
            }
          },
          "then": {
            "required": [
              "triage_level",
              "category",
              "judge_reason_code"
            ]
          }
        }
      ],
      "properties": {
        "category": {
          "$ref": "#/$defs/category"
        },
        "final_status": {
          "enum": [
            "SUCCESS",
            "TRIAGED"
          ],
          "type": "string"
        },
        "judge_reason_code": {
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "type": "string"
        },
        "triage_level": {
          "enum": [
            "ESCALATE",
            "FIXABLE"
          ],
          "type": "string"
        }
      },
      "required": [
        "final_status"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "coverage_tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "execution": {
      "additionalProperties": false,
      "properties": {
        "budgets": {
          "additionalProperties": false,
          "properties": {
            "limits": {
              "additionalProperties": false,
              "properties": {
                "max_attempts": {
                  "minimum": 0,
                  "type": "integer"
                },
                "max_external_queries": {
                  "minimum": 0,
                  "type": "integer"
                },
                "max_steps": {
                  "minimum": 0,
                  "type": "integer"
                },
                "max_wall_time_ms": {
                  "minimum": 0,
                  "type": "integer"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        },
        "build_target": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        },
        "fixture_dir": {
          "type": "string"
        },
        "main_decl": {
          "type": "string"
        },
        "main_module": {
          "type": "string"
        },
        "simulate_tooling_failure": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "expected": {
      "$ref": "#/$defs/expected"
    },
    "id": {
      "pattern": "^[a-z0-9][a-z0-9._-]*$",
      "type": "string"
    },
    "patch_sequence": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "tier": {
      "enum": [
        "smoke",
        "core",
        "nightly"
      ],
      "type": "string"
    }
  },
  "required": [
    "id",
    "tier",
    "expected",
    "coverage_tags"
  ],
  "title": "LeanAtlas E2E Case",
  "type": "object"
}
