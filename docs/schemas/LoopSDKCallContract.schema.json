{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "response": {
            "properties": {
              "status": {
                "const": "ERROR"
              }
            },
            "required": [
              "status"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "response": {
            "required": [
              "error"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "api_group": {
            "const": "loop/providers"
          }
        },
        "required": [
          "api_group"
        ]
      },
      "then": {
        "required": [
          "agent_provider",
          "instruction_scope_refs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "api_group": {
            "const": "loop/review-history"
          }
        },
        "required": [
          "api_group"
        ]
      },
      "then": {
        "required": [
          "review_history_ref"
        ]
      }
    },
    {
      "if": {
        "required": [
          "agent_provider"
        ]
      },
      "then": {
        "required": [
          "resolved_invocation_signature"
        ]
      }
    }
  ],
  "properties": {
    "actor_identity": {
      "minLength": 1,
      "type": "string"
    },
    "agent_profile": {
      "type": "string"
    },
    "agent_provider": {
      "minLength": 1,
      "type": "string"
    },
    "api_group": {
      "enum": [
        "loop/definitions",
        "loop/runs",
        "loop/graphs",
        "loop/components",
        "loop/resources",
        "loop/audit",
        "loop/providers",
        "loop/review-history"
      ],
      "type": "string"
    },
    "assurance_level": {
      "enum": [
        "FAST",
        "LIGHT",
        "STRICT"
      ],
      "type": "string"
    },
    "call_id": {
      "pattern": "^[A-Za-z0-9._-]+$",
      "type": "string"
    },
    "idempotency_key": {
      "minLength": 1,
      "type": "string"
    },
    "instruction_scope_refs": {
      "items": {
        "minLength": 1,
        "type": "string"
      },
      "minItems": 1,
      "type": "array"
    },
    "operation": {
      "minLength": 1,
      "type": "string"
    },
    "request": {
      "additionalProperties": true,
      "type": "object"
    },
    "resolved_invocation_signature": {
      "minLength": 1,
      "type": "string"
    },
    "response": {
      "additionalProperties": false,
      "properties": {
        "at_utc": {
          "format": "date-time",
          "type": "string"
        },
        "error": {
          "additionalProperties": false,
          "properties": {
            "error_class": {
              "enum": [
                "RETRYABLE_USER",
                "RETRYABLE_SYSTEM",
                "NON_RETRYABLE_CONTRACT",
                "NON_RETRYABLE_INFRA"
              ],
              "type": "string"
            },
            "error_code": {
              "pattern": "^[A-Z0-9_]+$",
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "retryable": {
              "type": "boolean"
            }
          },
          "required": [
            "error_code",
            "error_class",
            "retryable"
          ],
          "type": "object"
        },
        "result_ref": {
          "type": "string"
        },
        "status": {
          "enum": [
            "OK",
            "ERROR"
          ],
          "type": "string"
        },
        "trace_refs": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "status",
        "at_utc"
      ],
      "type": "object"
    },
    "review_history_ref": {
      "minLength": 1,
      "type": "string"
    },
    "version": {
      "const": "1",
      "type": "string"
    }
  },
  "required": [
    "version",
    "call_id",
    "api_group",
    "operation",
    "idempotency_key",
    "actor_identity",
    "request",
    "response"
  ],
  "title": "LoopSDKCallContract",
  "type": "object"
}
