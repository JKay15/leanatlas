    {
      "id": "nightly_chat_feedback_deposition",
      "status": "active",
      "mode": "MAINTAINER",
      "purpose": "Nightly: deposit curated chat feedback into digest + append-only ledger + traceability matrix for auditable closed-loop maintenance.",
      "trigger": {
        "type": "schedule",
        "cadence": "nightly"
      },
      "deterministic": {
        "steps": [
          {
            "name": "mine_chat_feedback",
            "cmd": [
              "python",
              "tools/feedback/mine_chat_feedback.py",
              "--in-root",
              "artifacts/feedback/inbox",
              "--out",
              "artifacts/feedback/chat_feedback/latest.json"
            ]
          },
          {
            "name": "append_feedback_ledger",
            "cmd": [
              "python",
              "tools/feedback/append_feedback_ledger.py",
              "--digest",
              "artifacts/feedback/chat_feedback/latest.json",
              "--ledger",
              "artifacts/feedback/ledger/feedback_ledger.jsonl",
              "--summary-out",
              "artifacts/feedback/ledger/latest_append_summary.json"
            ]
          },
          {
            "name": "build_traceability_matrix",
            "cmd": [
              "python",
              "tools/feedback/build_traceability_matrix.py",
              "--ledger",
              "artifacts/feedback/ledger/feedback_ledger.jsonl",
              "--out-csv",
              "artifacts/feedback/traceability/latest.csv",
              "--out-json",
              "artifacts/feedback/traceability/latest.json",
              "--strict-closed"
            ]
          }
        ],
        "artifacts": [
          "artifacts/feedback/chat_feedback/**",
          "artifacts/feedback/ledger/**",
          "artifacts/feedback/traceability/**"
        ]
      },
      "advisor": {
        "agent_provider": "codex_cli",
        "enabled": true,
        "when": "findings",
        "skill": "leanatlas-automations",
        "probe": {
          "kind": "json_field_gt",
          "path": "artifacts/feedback/ledger/latest_append_summary.json",
          "field": "new_items_count",
          "threshold": 0
        },
        "outputs": [
          "PR adding tests/docs/skills updates for newly deposited feedback items",
          "PR updating contract/docs when severity/SLA or triage policy drifts"
        ]
      },
      "verify": {
        "steps": [
          {
            "name": "core_tests",
            "cmd": [
              "python",
              "tests/run.py",
              "--tier",
              "core"
            ]
          }
        ]
      },
      "tdd": {
        "profile": "core",
        "dry_run": {
          "cmd": [
            "python",
            "tests/automation/dry_run_single.py",
            "--id",
            "nightly_chat_feedback_deposition"
          ]
        }
      }
    }
