        "profile": "core",
        "dry_run": {
          "cmd": [
            "python",
            "tests/automation/dry_run_single.py",
            "--id",
            "nightly_mcp_healthcheck"
          ]
        }
      }
    },
    {
      "id": "nightly_trace_mining",
      "status": "active",
      "mode": "MAINTAINER",
      "purpose": "Nightly: aggregate AttemptLog/RunReport telemetry into actionable failure patterns and propose next test cases.",
      "trigger": {
        "type": "schedule",
        "cadence": "nightly"
      },
      "deterministic": {
        "steps": [
          {
            "name": "collect_telemetry",
            "cmd": [
              "python",
              "tools/bench/collect_telemetry.py",
              "--repo-root",
              ".",
              "--out-root",
              "artifacts/telemetry",
              "--clean"
            ]
          },
          {
            "name": "mine",
            "cmd": [
              "python",
              "tools/bench/mine_attempt_logs.py",
              "--in",
              "artifacts/telemetry",
              "--out",
              "artifacts/bench/trace_mining/latest.json"
            ]
          }
        ],
        "artifacts": [
          "artifacts/telemetry/**",
          "artifacts/bench/trace_mining/**"
        ]
      },
      "advisor": {
        "agent_provider": "codex_cli",
        "enabled": true,
        "when": "findings",
        "skill": "leanatlas-automations",
        "probe": {
          "kind": "json_array_nonempty",
          "path": "artifacts/bench/trace_mining/latest.json",
          "field": "triage.top_failure_families"
        },
        "outputs": [
          "PR adding new e2e scenarios / updating skills _generated inputs"
        ]
      },
      "verify": {
        "steps": [
          {
            "name": "lake_test",
            "cmd": [
              "lake",
              "test"
            ]
          }
        ]
      },
      "tdd": {
        "profile": "core",
        "dry_run": {
          "cmd": [
            "python",
            "tests/automation/dry_run_single.py",
            "--id",
            "nightly_trace_mining"
          ]
        }
      }
    },
    {
      "id": "weekly_kb_suggestions",
      "status": "active",
      "mode": "MAINTAINER",
      "purpose": "Weekly: mine stable KB/skills growth suggestions, run skills regeneration audit, and produce deterministic stubs for closed-loop maintenance.",
      "trigger": {
        "type": "schedule",
        "cadence": "weekly"
      },
      "deterministic": {
        "steps": [
          {
            "name": "collect_telemetry",
            "cmd": [
              "python",
              "tools/bench/collect_telemetry.py",
              "--repo-root",
              ".",
              "--out-root",
              "artifacts/telemetry",
              "--clean"
            ]
          },
          {
            "name": "mine_kb_suggestions",
            "cmd": [
              "python",
              "tools/bench/mine_kb_suggestions.py",
              "--in",
              "artifacts/telemetry",
              "--out",
              "artifacts/skills_regen/kb_suggestions.json"
            ]
          },
          {
            "name": "skills_regen_check",
            "cmd": [
              "python",
              "tools/coordination/skills_regen.py",
              "--repo-root",
              ".",
              "--out",
              "artifacts/skills_regen/view.json",
              "--audit-out",
              "artifacts/skills_regen/audit.json",
              "--check"
            ]
          },
          {
            "name": "skills_stub_plan",
            "cmd": [
              "python",
              "tools/coordination/skills_stubgen.py",
              "--repo-root",
              ".",
              "--out",
              "artifacts/skills_regen/stub_plan.json"
            ]
          }
        ],
        "artifacts": [
          "artifacts/telemetry/**",
          "artifacts/skills_regen/**"
        ]
      },
      "advisor": {
        "agent_provider": "codex_cli",
        "enabled": true,
        "when": "findings",
        "skill": "leanatlas-automations",
        "probe": {
          "kind": "json_array_nonempty",
          "path": "artifacts/skills_regen/kb_suggestions.json",
          "field": "suggestions"
        },
        "outputs": [
          "Change Proposal PR updating docs/agents/kb/* based on recurring patterns",
          "Change Proposal PR updating .agents/skills/* when routing/procedures need correction",
          "Patch proposal for tools/coordination/skills_regen.py or skills coverage metadata when audit fails"
        ]
      },
      "verify": {
        "steps": [
          {
            "name": "core_tests",
            "cmd": [
              "python",
              "tests/run.py",
              "--tier",
              "core"
            ]
          }
        ]
      },
      "tdd": {
        "profile": "core",
        "dry_run": {
          "cmd": [
            "python",
            "tests/automation/dry_run_single.py",
            "--id",
            "weekly_kb_suggestions"
          ]
        }
      }
    },
