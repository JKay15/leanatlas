{
  "version": "1",
  "automations": [
    {
      "id": "nightly_reporting_integrity",
      "status": "active",
      "mode": "MAINTAINER",
      "purpose": "Nightly: verify reporting schemas + canonical determinism never drift.",
      "trigger": {
        "type": "schedule",
        "cadence": "nightly"
      },
      "deterministic": {
        "steps": [
          {
            "name": "schema_validate",
            "cmd": [
              "python",
              "tests/schema/validate_schemas.py"
            ]
          },
          {
            "name": "canonical_json",
            "cmd": [
              "python",
              "tests/determinism/check_canonical_json.py"
            ]
          }
        ],
        "artifacts": [
          "artifacts/automation/nightly_reporting_integrity/**"
        ]
      },
      "advisor": {
        "enabled": false,
        "notes": "No Codex needed unless this fails. If it fails, open a PR fixing contracts/schemas/examples/fixtures."
      },
      "verify": {
        "steps": [
          {
            "name": "lake_lint",
            "cmd": [
              "lake",
              "lint"
            ]
          },
          {
            "name": "lake_test",
            "cmd": [
              "lake",
              "test"
            ]
          }
        ]
      },
      "tdd": {
        "profile": "core",
        "dry_run": {
          "cmd": [
            "python",
            "tests/automation/dry_run_single.py",
            "--id",
            "nightly_reporting_integrity"
          ]
        }
      }
    },
    {
